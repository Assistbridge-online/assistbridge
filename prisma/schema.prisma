// Production schema — PostgreSQL for Vercel/Neon/Supabase deployment.
// For local SQLite dev, swap provider back to "sqlite" and DATABASE_URL to "file:./dev.db".
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  hashedPassword  String?
  role            String    @default("CLIENT")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  clientProfile   ClientProfile?
  expertProfile   ExpertProfile?
  ordersAsClient  Order[]        @relation("ClientOrders")
  ordersAsExpert  Order[]        @relation("ExpertOrders")
  messages        Message[]
  reviewsGiven    Review[]       @relation("ReviewAuthor")
  reviewsReceived Review[]       @relation("ReviewTarget")
  attachments     Attachment[]
  disputes        Dispute[]      @relation("DisputeOpener")
  supportTickets  SupportTicket[] @relation("SupportAssignee")
  blogPosts       BlogPost[]
  faqs            Faq[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClientProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  company                String?
  country                String?
  defaultPaymentMethodId String?
  photoSeed              Int?     // deterministic seed for adult portrait (randomuser.me)
  photoUrl               String?  // override URL if user provided their own
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExpertProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  bio           String?
  headline      String?
  hourlyRate    Float?
  currency      String   @default("USD")
  expertise     String
  languages     String   @default("English")
  education     String?
  yearsExp      Int?
  status        String   @default("PENDING")
  rating        Float    @default(0)
  completedJobs Int      @default(0)
  cvUrl         String?
  sampleWorkUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Discipline {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String
  longDescription String?
  icon            String?
  tools           String?
  servicesList    String?
  order           Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parentId String?
  parent   Discipline?  @relation("SubDisciplines", fields: [parentId], references: [id])
  children Discipline[] @relation("SubDisciplines")
  services Service[]
}

model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String
  shortDescription String?
  category         String
  icon             String?

  // Per-page pricing
  pricePerPage   Float    @default(0)
  minPages       Int      @default(1)
  maxPages       Int?
  pageUnit       String   @default("page")
  wordsPerPage   Int      @default(250)

  basePrice      Float?
  rushMultiplier Float    @default(1.5)

  deliverables   String?
  turnaroundDays Int      @default(7)
  active         Boolean  @default(true)
  featured       Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  disciplineId String?
  discipline   Discipline? @relation(fields: [disciplineId], references: [id])
  orders       Order[]
  academicPrices ServiceAcademicPrice[]
}

model AcademicLevel {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  degreeTypes String?
  order       Int     @default(0)
  active      Boolean @default(true)

  prices ServiceAcademicPrice[]
  orders Order[]
}

model ServiceAcademicPrice {
  id              String  @id @default(cuid())
  serviceId       String
  academicLevelId String
  pricePerPage    Float
  wordsPerPage    Int     @default(250)
  minPages        Int     @default(1)
  rushMultiplier  Float   @default(1.5)
  active          Boolean @default(true)

  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  academicLevel AcademicLevel @relation(fields: [academicLevelId], references: [id], onDelete: Cascade)

  @@unique([serviceId, academicLevelId])
}

model Order {
  id           String   @id @default(cuid())
  clientId     String
  expertId     String?
  serviceId    String?
  academicLevelId String?
  subject      String?
  title        String
  brief        String
  pageCount    Int?
  deadline     DateTime?
  deadlineType String   @default("standard")
  quotedPrice  Float?
  finalPrice   Float?
  currency     String   @default("USD")
  status       String   @default("DRAFT")
  attachmentsUploaded Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client       User      @relation("ClientOrders", fields: [clientId], references: [id])
  expert       User?     @relation("ExpertOrders", fields: [expertId], references: [id])
  service      Service?  @relation(fields: [serviceId], references: [id])
  academicLevel AcademicLevel? @relation(fields: [academicLevelId], references: [id])
  messages     Message[]
  attachments  Attachment[]
  payments     Payment[]
  review       Review?
  dispute      Dispute?
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  gateway    String
  amount     Float
  currency   String   @default("USD")
  status     String   @default("PENDING")
  gatewayRef String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  orderId    String   @unique
  fromUserId String
  toUserId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromUser User  @relation("ReviewAuthor", fields: [fromUserId], references: [id])
  toUser   User  @relation("ReviewTarget", fields: [toUserId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  orderId    String
  fromUserId String
  body       String
  createdAt  DateTime @default(now())

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromUser    User         @relation(fields: [fromUserId], references: [id])
  attachments Attachment[]
}

model Attachment {
  id        String   @id @default(cuid())
  ownerId   String
  url       String
  filename  String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [orderId], references: [id])
  orderId   String?
  message   Message?  @relation(fields: [messageId], references: [id])
  messageId String?
}

model Dispute {
  id         String   @id @default(cuid())
  orderId    String   @unique
  openedById String
  reason     String
  status     String   @default("OPEN")
  resolution String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  openedBy User  @relation("DisputeOpener", fields: [openedById], references: [id])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model ExpertApplication {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  expertise     String
  bio           String
  hourlyRate    Float?
  currency      String   @default("USD")
  cvUrl         String?
  sampleWorkUrl String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  projectType String
  scope       String
  budget      String
  createdAt   DateTime @default(now())
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String
  country    String?
  quote      String
  rating     Int      @default(5)
  avatarSeed Int?
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model TeamMember {
  id         String   @id @default(cuid())
  name       String
  role       String
  bio        String
  avatarSeed Int?
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Subject {
  id             String   @id @default(cuid())
  name           String
  levelSlug      String
  department     String?
  courseCode     String?
  description    String?
  priceMultiplier Float   @default(1.0)
  institutions   String?
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, levelSlug])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  active    Boolean  @default(true)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  body        String
  category    String    @default("General")
  image       String?
  readTime    String    @default("5 min")
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PricingTier {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  blurb        String
  pricePerPage Float?
  minPages     Int      @default(1)
  includedPages Int?
  flatPrice    Float?
  features     String
  ctaLabel     String   @default("Get started")
  ctaHref      String   @default("/dashboard/new")
  featured     Boolean  @default(false)
  order        Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PricingConfig {
  id                     String   @id @default(cuid())
  pageUnitLabel          String   @default("page")
  wordsPerPage           Int      @default(250)
  platformFeePercent     Float    @default(15)
  rushDeliveryDays       Int      @default(3)
  rushMultiplier         Float    @default(1.5)
  studentDiscountPercent Float    @default(10)
  nonProfitDiscountPercent Float  @default(10)
  updatedAt              DateTime @updatedAt
  singleton              String   @unique @default("singleton")
}

model SiteStat {
  id        String   @id @default(cuid())
  label     String   @unique
  value     String
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String    @default("footer")
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, code])
}

// ============================================================
// Support inbox (inbound + outbound support email)
// ============================================================
// One SupportTicket per customer conversation. Each new inbound email
// from a known thread becomes a new SupportMessage on the same ticket.
// Replies from the admin go out through Resend with In-Reply-To set
// to the customer's most recent message Message-ID, so the customer's
// email client threads them into the same conversation.

model SupportTicket {
  id          String   @id @default(cuid())
  // First message's Message-ID — used to dedupe the initial inbound
  // webhook event in case Resend retries it.
  rootMessageId String  @unique
  // Customer identity (denormalized; we don't require a User row
  // because inbound email can come from anyone, including non-users).
  fromEmail   String
  fromName    String?
  subject     String
  status      String   @default("OPEN") // OPEN | PENDING | CLOSED
  assigneeId  String?
  assignee    User?    @relation("SupportAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  lastMessageAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    SupportMessage[]
  attachments SupportAttachment[]

  @@index([status, lastMessageAt])
  @@index([fromEmail])
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Direction: "INBOUND" (from customer) | "OUTBOUND" (admin reply)
  direction   String
  // Sender: "customer" for inbound, the admin user's name/email for outbound
  fromEmail   String
  fromName    String?
  // Resend email_id for the outbound message, or their email_id for inbound
  resendId    String?  @unique
  // RFC 5322 Message-ID header (for threading via In-Reply-To)
  messageId   String   @unique
  inReplyTo   String?
  references  String?
  // Plain-text body (we store text + html; html is generated at send time
  // from text by lib/email-templates)
  bodyText    String
  bodyHtml    String
  // For inbound, the raw raw from the Resend webhook event (debug aid)
  raw         String?
  // Set true on the first message of a ticket (used by the inbox list)
  isFirst     Boolean  @default(false)
  createdAt   DateTime @default(now())

  attachments SupportAttachment[]

  @@index([ticketId, createdAt])
}

model SupportAttachment {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messageId   String?
  message     SupportMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  // Resend's attachment id; we fetch bytes on demand via the Resend
  // SDK and re-host on our CDN. For now we store the URL + metadata
  // and proxy downloads through /api/admin/support/attachments/[id].
  resendAttachmentId String
  filename    String
  contentType String
  size        Int
  // Optional local URL once downloaded (e.g. S3 / Vercel Blob)
  storedUrl   String?
  createdAt   DateTime @default(now())

  @@index([ticketId])
}
